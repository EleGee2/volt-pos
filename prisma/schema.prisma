// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UnitOfMeasure {
  PIECE
  METER
  ROLL
  COIL
  CARTON
}

enum SaleStatus {
  COMPLETED
  VOIDED
  PENDING_SYNC
  STOCK_CONFLICT
  RETURNED
  PARTIALLY_RETURNED
}

enum MovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  TRANSFER_OUT
  TRANSFER_IN
  CONFLICT_ADJUSTMENT
  RETURN
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
}

model Organization {
  id                   String           @id @default(uuid()) @db.Uuid
  name                 String           @db.VarChar(255)
  slug                 String           @unique @db.VarChar(100)
  subscriptionPlan     SubscriptionPlan @default(FREE) @map("subscription_plan")
  defaultVatRate       Decimal          @default(0) @db.Decimal(5, 2) @map("default_vat_rate")
  trialEndsAt          DateTime?        @map("trial_ends_at") @db.Timestamptz()
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  products             Product[]
  sales                Sale[]
  locations            Location[]
  users                User[]

  @@map("organizations")
}

model Location {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  name                  String   @db.VarChar(255)
  logoUrl               String?  @db.Text @map("logo_url")
  phone                 String?  @db.VarChar(30)
  email                 String?  @db.VarChar(255)
  addressStreet         String?  @db.VarChar(255) @map("address_street")
  addressCity           String?  @db.VarChar(100) @map("address_city")
  addressState          String?  @db.VarChar(100) @map("address_state")
  addressCountry        String?  @db.VarChar(100) @map("address_country")
  addressPostalCode     String?  @db.VarChar(20) @map("address_postal_code")
  taxRegistrationNumber String?  @db.VarChar(100) @map("tax_registration_number")
  currencyCode          String   @default("USD") @db.VarChar(3) @map("currency_code")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  organization    Organization     @relation(fields: [organizationId], references: [id])
  inventoryLevels InventoryLevel[]
  sales           Sale[]

  @@map("locations")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  email           String   @unique @db.VarChar(255)
  passwordHash    String   @map("password_hash") @db.Text
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  role            UserRole @default(CASHIER)
  pinHash         String?  @map("pin_hash") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  organization    Organization @relation(fields: [organizationId], references: [id])
  sales           Sale[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.Text
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user      User     @relation(fields: [userId], references: [id])

  @@map("password_reset_tokens")
}

model Product {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String        @db.VarChar(255)
  sku            String        @db.VarChar(100)
  barcode        String?       @db.VarChar(100)
  categoryId     String?       @map("category_id") @db.Uuid
  unitOfMeasure  UnitOfMeasure @map("unit_of_measure")
  costPrice      Decimal       @db.Decimal(12, 2) @map("cost_price")
  sellingPrice   Decimal       @db.Decimal(12, 2) @map("selling_price")
  taxRate        Decimal       @default(-1) @db.Decimal(5, 2) @map("tax_rate")
  reorderLevel   Decimal       @default(0) @db.Decimal(10, 3) @map("reorder_level")
  isBundle       Boolean       @default(false) @map("is_bundle")
  isActive       Boolean       @default(true) @map("is_active")

  organization    Organization     @relation(fields: [organizationId], references: [id])
  category        Category?        @relation(fields: [categoryId], references: [id])
  inventoryLevels InventoryLevel[]
  saleItems       SaleItem[]
  stockMovements  StockMovement[]

  @@unique([organizationId, sku])
  @@map("products")
}

model Category {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(255)

  products Product[]

  @@map("categories")
}

model InventoryLevel {
  id               String   @id @default(uuid()) @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  locationId       String   @map("location_id") @db.Uuid
  currentQuantity  Decimal  @default(0) @db.Decimal(10, 3) @map("current_quantity")
  reservedQuantity Decimal  @default(0) @db.Decimal(10, 3) @map("reserved_quantity")
  lastUpdatedAt    DateTime @default(now()) @map("last_updated_at") @db.Timestamptz()

  product          Product  @relation(fields: [productId], references: [id])
  location         Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
  @@map("inventory_levels")
}

model Sale {
  id                 String     @id @default(uuid()) @db.Uuid
  organizationId     String     @map("organization_id") @db.Uuid
  locationId         String     @map("location_id") @db.Uuid
  cashierId          String     @map("cashier_id") @db.Uuid
  customerId         String?    @map("customer_id") @db.Uuid
  totalAmount        Decimal    @db.Decimal(12, 2) @map("total_amount")
  subtotalAmount     Decimal    @db.Decimal(12, 2) @map("subtotal_amount")
  vatAmount          Decimal    @default(0) @db.Decimal(12, 2) @map("vat_amount")
  discountAmount     Decimal    @default(0) @db.Decimal(12, 2) @map("discount_amount")
  status             SaleStatus
  deviceTimestamp    DateTime?  @map("device_timestamp") @db.Timestamptz()
  serverReceivedAt   DateTime   @default(now()) @map("server_received_at") @db.Timestamptz()
  syncedFromOffline  Boolean    @default(false) @map("synced_from_offline")
  receiptUrl         String?    @db.Text @map("receipt_url")

  organization       Organization @relation(fields: [organizationId], references: [id])
  location           Location     @relation(fields: [locationId], references: [id])
  cashier            User         @relation(fields: [cashierId], references: [id])
  customer           Customer?    @relation(fields: [customerId], references: [id])
  saleItems          SaleItem[]

  @@map("sales")
}

model Customer {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String   @db.VarChar(255)
  phone           String?  @db.VarChar(30)
  creditLimit     Decimal  @default(0) @db.Decimal(12, 2) @map("credit_limit")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  sales           Sale[]

  @@map("customers")
}

model SaleItem {
  id                  String  @id @default(uuid()) @db.Uuid
  saleId              String  @map("sale_id") @db.Uuid
  productId           String  @map("product_id") @db.Uuid
  quantity            Decimal @db.Decimal(10, 3)
  unitPrice           Decimal @db.Decimal(12, 2) @map("unit_price")
  unitCostSnapshot    Decimal @db.Decimal(12, 2) @map("unit_cost_snapshot")
  taxRateSnapshot     Decimal @db.Decimal(5, 2) @map("tax_rate_snapshot")
  vatAmount           Decimal @default(0) @db.Decimal(12, 2) @map("vat_amount")
  discountAmount      Decimal @default(0) @db.Decimal(12, 2) @map("discount_amount")
  belowCostOverride   Boolean @default(false) @map("below_cost_override")

  sale                Sale    @relation(fields: [saleId], references: [id])
  product             Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model StockMovement {
  id             String       @id @default(uuid()) @db.Uuid
  productId      String       @map("product_id") @db.Uuid
  locationId     String       @map("location_id") @db.Uuid
  movementType   MovementType @map("movement_type")
  quantityDelta  Decimal      @db.Decimal(10, 3) @map("quantity_delta")
  referenceId    String?      @map("reference_id") @db.Uuid
  createdBy      String       @map("created_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  notes          String?      @db.Text

  product        Product      @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}
